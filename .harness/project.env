# Optional explicit GitHub repo slug. Leave empty to auto-detect from origin.
HARNESS_REPO_SLUG=""

# Default git base branch for new task worktrees.
HARNESS_BASE_BRANCH="main"

# Branch prefix for issue-backed tasks.
HARNESS_BRANCH_PREFIX="fix/issue-"

# Branch prefix for local/non-issue tasks.
HARNESS_GENERIC_BRANCH_PREFIX="task/"

# Default worker runtime for auto-launch.
HARNESS_AGENT_DEFAULT="codex"

# Default log directory for autonomous worker runs.
HARNESS_LOG_DIR=""

# Default label filter for autonomous issue consumers. Leave empty to consume any eligible issue.
HARNESS_AUTONOMOUS_LABEL=""

# Target wake interval for cron-based autonomous workers.
HARNESS_CRON_INTERVAL_MINUTES="5"

# Max runtime per one-shot lane worker. Set to 0 to disable the timeout.
HARNESS_EXECUTOR_TIMEOUT_SECONDS="240"
# Max unresolved executor tasks allowed before task-run-once refuses to claim more work.
HARNESS_EXECUTOR_ACTIVE_LIMIT="1"
HARNESS_REVIEW_TIMEOUT_SECONDS="180"
HARNESS_PREPARE_TIMEOUT_SECONDS="300"
HARNESS_LAND_TIMEOUT_SECONDS="120"

# Commands file used by task-prepare. One shell command per line.
HARNESS_PREPARE_COMMANDS_FILE=""

# Merge method for task-land: squash | merge | rebase
HARNESS_MERGE_METHOD="squash"

# Require remote GitHub checks to be green before task-land merges.
HARNESS_REQUIRE_GREEN_CHECKS="0"

# GitHub labels used by the harness.
HARNESS_LABEL_ACTIVE="harness:in-progress"
HARNESS_LABEL_PR_OPEN="harness:pr-open"
HARNESS_LABEL_DONE="harness:done"
HARNESS_LABEL_BLOCKED="harness:blocked"

# Claim expiry used by task-next/task-start when pruning stale claims.
HARNESS_CLAIM_TTL_MINUTES="240"
