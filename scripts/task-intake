#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=./harness-lib.sh
source "$SCRIPT_DIR/harness-lib.sh"

title=""
body=""
body_file=""
start=0
local_only=0
labels=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --title)
      title="${2:-}"
      shift 2
      ;;
    --body)
      body="${2:-}"
      shift 2
      ;;
    --body-file)
      body_file="${2:-}"
      shift 2
      ;;
    --label)
      labels+=("${2:-}")
      shift 2
      ;;
    --start)
      start=1
      shift
      ;;
    --local)
      local_only=1
      shift
      ;;
    -h|--help)
      cat <<'EOF'
usage: scripts/task-intake --title <title> [--body <text> | --body-file <path>] [--label <label>]... [--start] [--local]
EOF
      exit 0
      ;;
    *)
      harness_die "unknown argument: $1"
      ;;
  esac
done

[[ -n "$title" ]] || harness_die "provide --title"

if [[ -n "$body_file" ]]; then
  [[ -f "$body_file" ]] || harness_die "body file not found: $body_file"
  body=$(cat "$body_file")
fi

if [[ -z "$body" ]]; then
  body=$(cat <<EOF
## Problem

- 

## Desired Outcome

- 

## Constraints

- 

## Evidence

- 
EOF
)
fi

if [[ "$local_only" -eq 1 ]]; then
  task_id=$(harness_slugify "$title")
  if [[ "$start" -eq 1 ]]; then
    exec "$SCRIPT_DIR/task-start" --task-id "$task_id" --title "$title" --body "$body"
  fi

  printf 'local task draft:\n'
  printf '  scripts/task-start --task-id %q --title %q --body %q\n' "$task_id" "$title" "$body"
  exit 0
fi

harness_can_sync_github || harness_die "GitHub sync is unavailable; check gh auth and repo remote."
repo_slug=$(harness_repo_slug)

create_args=(issue create -R "$repo_slug" --title "$title" --body "$body")
for label in "${labels[@]-}"; do
  create_args+=(--label "$label")
done

issue_url=$(gh "${create_args[@]}")
issue_number="${issue_url##*/}"

printf 'issue created: #%s\n' "$issue_number"
printf '%s\n' "$issue_url"

if [[ "$start" -eq 1 ]]; then
  exec "$SCRIPT_DIR/task-start" --issue "$issue_number"
fi
