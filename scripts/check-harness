#!/usr/bin/env bash

set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
if common_git_dir=$(git -C "$script_dir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null); then
  root=$(dirname "$common_git_dir")
else
  root=$(git -C "$script_dir" rev-parse --show-toplevel)
fi
cd "$root"

scripts=(
  scripts/harness-lib.sh
  scripts/check-harness
  scripts/openclaw-manager-setup
  scripts/task-create
  scripts/task-finish
  scripts/task-intake
  scripts/task-land
  scripts/task-land-once
  scripts/task-next
  scripts/task-prepare
  scripts/task-prepare-once
  scripts/task-review
  scripts/task-review-once
  scripts/task-run-once
  scripts/task-start
)

bash -n "${scripts[@]}"
printf 'check-harness passed\n'
