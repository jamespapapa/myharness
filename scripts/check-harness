#!/usr/bin/env bash

set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
root=$(git -C "$script_dir" rev-parse --show-toplevel)
cd "$root"

scripts=(
  scripts/harness-lib.sh
  scripts/check-harness
  scripts/check-task-control-room-once
  scripts/check-task-run-once
  scripts/openclaw-manager-setup
  scripts/task-control-room-once
  scripts/task-create
  scripts/task-finish
  scripts/task-intake
  scripts/task-land
  scripts/task-land-once
  scripts/task-next
  scripts/task-prepare
  scripts/task-prepare-once
  scripts/task-review
  scripts/task-review-once
  scripts/task-run-once
  scripts/task-start
)

bash -n "${scripts[@]}"
scripts/check-task-control-room-once
scripts/check-task-run-once
printf 'check-harness passed\n'
