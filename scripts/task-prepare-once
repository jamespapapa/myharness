#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=./harness-lib.sh
source "$SCRIPT_DIR/harness-lib.sh"

log_file=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --log-file)
      log_file="${2:-}"
      shift 2
      ;;
    -h|--help)
      echo "usage: scripts/task-prepare-once [--log-file <path>]"
      exit 0
      ;;
    *)
      harness_die "unknown argument: $1"
      ;;
  esac
done

harness_load_project_env
harness_prepare_state
[[ -n "$log_file" ]] || log_file="$HARNESS_LOG_DIR/task-prepare-once.jsonl"

emit_log() {
  jq -nc --arg ts "$(harness_now_utc)" --arg status "$1" --arg task_id "${2:-}" --arg detail "${3:-}" \
    '{ts:$ts,status:$status,task_id:$task_id,detail:$detail}' >>"$log_file"
}

next_task=$(harness_find_next_task_by_status "reviewed" || true)
if [[ -z "$next_task" ]]; then
  detail="prepare lane idle; no reviewed task found"
  emit_log "idle" "" "$detail"
  harness_control_room_idle_line

  exit 0
fi

task_id=$(printf '%s' "$next_task" | jq -r '.task_id')

if ! output=$("$SCRIPT_DIR/task-prepare" --task-id "$task_id" 2>&1); then
  if [[ "$output" == *"claimed by another prepare worker"* ]]; then
    detail="prepare lane waiting on $task_id; $output"
    emit_log "waiting" "$task_id" "$detail"
    printf 'waiting: %s\n' "$detail"
    exit 0
  fi
  status=$(harness_task_field "$task_id" '.status // ""' 2>/dev/null || true)
  if [[ "$status" == "prepare_failed" || "$status" == "blocked" ]]; then
    detail="prepare lane blocked $task_id; $output"
    emit_log "blocked" "$task_id" "$detail"
    printf 'blocked: %s\n' "$detail"
    exit 2
  fi
  detail="prepare lane error on $task_id; $output"
  emit_log "error" "$task_id" "$detail"
  printf 'error: %s\n' "$detail" >&2
  exit 1
fi

status=$(harness_task_field "$task_id" '.status // ""')
case "$status" in
  prepared)
    detail="prepare lane passed $task_id"
    emit_log "success" "$task_id" "$detail"
    printf 'success: %s\n' "$detail"
    ;;
  pr_open)
    detail="prepare lane left $task_id in pr_open; $output"
    emit_log "waiting" "$task_id" "$detail"
    printf 'waiting: %s\n' "$detail"
    ;;
  *)
    detail="prepare lane ended with unexpected status=$status for $task_id; $output"
    emit_log "error" "$task_id" "$detail"
    printf 'error: %s\n' "$detail" >&2
    exit 1
    ;;
esac
