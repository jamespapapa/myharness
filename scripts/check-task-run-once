scenario_waits_when_queue_empty_but_active_work_remains() {
  local now_epoch now_iso output

  setup_fixture "queue-empty-wait"
  now_epoch=$(date -u +%s)
  now_iso=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  mkdir -p "$REPO_DIR/.harness/tasks/issue-9001" "$WORKTREE_ROOT/issue-9001"

  cat >"$REPO_DIR/.harness/tasks/issue-9001/task.json" <<EOF
{
  "task_id": "issue-9001",
  "issue_number": 9001,
  "title": "Still running",
  "repo_slug": "example/test-harness",
  "branch": "fix/issue-9001",
  "base_branch": "dev",
  "worktree": "$WORKTREE_ROOT/issue-9001",
  "status": "in_progress",
  "created_at": "$now_iso",
  "updated_at": "$now_iso"
}
EOF

  mkdir -p "$REPO_DIR/.harness/state"
  cat >"$REPO_DIR/.harness/state/claims.json" <<EOF
{
  "example/test-harness#9001": {
    "repo": "example/test-harness",
    "issue_number": 9001,
    "task_id": "issue-9001",
    "branch": "fix/issue-9001",
    "worktree": "$WORKTREE_ROOT/issue-9001",
    "agent": "codex",
    "status": "in_progress",
    "claimed_at": "$now_iso",
    "claimed_epoch": $now_epoch
  }
}
EOF

  write_issue_list '[]'

  output=$(task_env HARNESS_MOCK_CODEX_MODE="no-op" "$REPO_DIR/scripts/task-run-once")
  assert_contains "$output" "waiting: ready queue empty; active work still assigned/running/reconciling;" "queue-empty should not report idle while active work remains"
  assert_contains "$output" "assigned=0 running=1 reconciling=0 total=1 limit=1" "queue-empty waiting output should describe active running work"
}

scenario_recovers_stale_in_progress_task() {
  local stale_epoch stale_iso output status claim_count

  setup_fixture "recover-stale"
  stale_epoch=$(( $(date -u +%s) - 10 ))
  stale_iso=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  git -C "$REPO_DIR" checkout -q -b fix/issue-9001 dev
  printf '\nStale ACP worktree change.\n' >>"$REPO_DIR/README.md"

  mkdir -p "$REPO_DIR/.harness/tasks/issue-9001" "$REPO_DIR/.harness/state"
  cat >"$REPO_DIR/.harness/tasks/issue-9001/task.json" <<EOF
{
  "task_id": "issue-9001",
  "issue_number": 9001,
  "title": "Recover stale in-progress issue",
  "repo_slug": "example/test-harness",
  "branch": "fix/issue-9001",
  "base_branch": "dev",
  "worktree": "$REPO_DIR",
  "status": "in_progress",
  "created_at": "$stale_iso",
  "updated_at": "$stale_iso"
}
EOF

  cat >"$REPO_DIR/.harness/state/claims.json" <<EOF
{
  "example/test-harness#9001": {
    "repo": "example/test-harness",
    "issue_number": 9001,
    "task_id": "issue-9001",
    "branch": "fix/issue-9001",
    "worktree": "$REPO_DIR",
    "agent": "codex",
    "status": "reconciling",
    "claimed_at": "$stale_iso",
    "claimed_epoch": $stale_epoch,
    "worker_log": "$REPO_DIR/.harness/logs/issue-9001.log",
    "worker_exit": "0"
  }
}
EOF

  write_issue_list '[]'

  output=$(task_env HARNESS_MOCK_CODEX_MODE="no-op" "$REPO_DIR/scripts/task-run-once")
  assert_eq "$output" "success: reconciled issue #9001 -> PR https://example.test/pr/9001" "stale in_progress task should reconcile to pr_open"

  status=$(jq -r '.status' "$REPO_DIR/.harness/tasks/issue-9001/task.json")
  assert_eq "$status" "pr_open" "stale task should no longer be in_progress"

  claim_count=$(jq 'length' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$claim_count" "0" "stale claim should be removed after reconciliation"
}

scenario_dispatch_only_records_assignment() {
  local output claim_status task_status assignment_slot assignment_channel assigned_by worker_log claim_summary

  setup_fixture "dispatch-only"
  write_mock_issue 9010 "Dispatch only issue" '[{"name":"Ready"}]'
  write_issue_list '[{"number":9010,"title":"Dispatch only issue","labels":[{"name":"Ready"}]}]'

  output=$(task_env HARNESS_MOCK_CODEX_MODE="touch-readme" "$REPO_DIR/scripts/task-run-once" --dispatch-only --assign-slot slot-a --assign-channel exec-a)
  assert_eq "$output" "success: dispatched issue #9010 -> exec-a/slot-a" "dispatch-only mode should claim and assign without launching Codex"

  claim_status=$(jq -r '."example/test-harness#9010".status' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$claim_status" "assigned" "dispatch-only should leave the claim in assigned status"

  task_status=$(jq -r '.status' "$REPO_DIR/.harness/tasks/issue-9010/task.json")
  assert_eq "$task_status" "assigned" "dispatch-only should leave the task assigned until a worker starts it"

  assignment_slot=$(jq -r '.assignment.slot // ""' "$REPO_DIR/.harness/tasks/issue-9010/task.json")
  assert_eq "$assignment_slot" "slot-a" "task record should store the assigned slot"

  assignment_channel=$(jq -r '.assignment.channel // ""' "$REPO_DIR/.harness/tasks/issue-9010/task.json")
  assert_eq "$assignment_channel" "exec-a" "task record should store the assigned channel"

  assigned_by=$(jq -r '.assignment.assigned_by // ""' "$REPO_DIR/.harness/tasks/issue-9010/task.json")
  assert_eq "$assigned_by" "task-run-once" "direct dispatch should record task-run-once as the assignment owner"

  worker_log=$(jq -r '."example/test-harness#9010".worker_log // ""' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$worker_log" "" "dispatch-only should not launch the worker"

  claim_summary=$(jq -r '.last_stage_summary.happened // ""' "$REPO_DIR/.harness/tasks/issue-9010/task.json")
  assert_contains "$claim_summary" "assigned the task to exec-a/slot-a" "claim summary should mention the assignment target"
}

scenario_assigned_only_does_not_fetch_queue() {
  local output

  setup_fixture "assigned-idle"
  write_mock_issue 9011 "Queued but unassigned issue" '[{"name":"Ready"}]'
  write_issue_list '[{"number":9011,"title":"Queued but unassigned issue","labels":[{"name":"Ready"}]}]'

  output=$(task_env HARNESS_MOCK_CODEX_MODE="touch-readme" "$REPO_DIR/scripts/task-run-once" --assigned-only --assign-slot slot-a --assign-channel exec-a)
  assert_eq "$output" "idle: no task assigned to exec-a/slot-a" "assigned-only mode should stay queue-blind when nothing is assigned"

  if [[ -e "$REPO_DIR/.harness/tasks/issue-9011/task.json" ]]; then
    printf 'assigned-only mode should not have materialized a queued issue without an assignment\n' >&2
    exit 1
  fi
}

scenario_dispatch_only_rework_stays_assigned() {
  local output claim_status task_status worker_log assignment_slot assignment_channel note

  setup_fixture "dispatch-rework"
  write_mock_issue 9013 "Dispatch rework issue" '[{"name":"Ready"}]'
  write_issue_list '[]'

  task_env "$REPO_DIR/scripts/task-start" --issue 9013 --assign-slot slot-r --assign-channel exec-r >/dev/null
  jq '
    .status = "rework"
    | .pr_url = "https://example.test/pr/9013"
    | .review_rework_attempts = 1
    | .review_rework_limit = 3
  ' "$REPO_DIR/.harness/tasks/issue-9013/task.json" > "$REPO_DIR/.harness/tasks/issue-9013/task.json.tmp"
  mv "$REPO_DIR/.harness/tasks/issue-9013/task.json.tmp" "$REPO_DIR/.harness/tasks/issue-9013/task.json"
  printf '{}
' > "$REPO_DIR/.harness/state/claims.json"

  output=$(task_env HARNESS_MOCK_CODEX_MODE="touch-readme" "$REPO_DIR/scripts/task-run-once" --dispatch-only --assign-slot slot-r --assign-channel exec-r)
  assert_eq "$output" "success: dispatched review rework issue #9013 -> exec-r/slot-r" "dispatch-only mode should assign queued rework instead of launching it locally"

  claim_status=$(jq -r '"example/test-harness#9013" as $k | .[$k].status // ""' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$claim_status" "assigned" "dispatch-only rework should leave the claim assigned"

  worker_log=$(jq -r '"example/test-harness#9013" as $k | .[$k].worker_log // ""' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$worker_log" "" "dispatch-only rework should not launch the worker"

  task_status=$(jq -r '.status' "$REPO_DIR/.harness/tasks/issue-9013/task.json")
  assert_eq "$task_status" "assigned" "dispatch-only rework should stay assigned until the designated worker resumes it"

  assignment_slot=$(jq -r '.assignment.slot // ""' "$REPO_DIR/.harness/tasks/issue-9013/task.json")
  assert_eq "$assignment_slot" "slot-r" "dispatch-only rework should preserve the assigned slot"

  assignment_channel=$(jq -r '.assignment.channel // ""' "$REPO_DIR/.harness/tasks/issue-9013/task.json")
  assert_eq "$assignment_channel" "exec-r" "dispatch-only rework should preserve the assigned channel"

  note=$(jq -r '.note // ""' "$REPO_DIR/.harness/tasks/issue-9013/task.json")
  assert_contains "$note" "assigned to exec-r/slot-r" "dispatch-only rework note should mention the assignment target"
}

scenario_stale_dispatch_rework_returns_to_rework() {
  local dispatch_output run_output stale_iso stale_epoch task_status claim_count pr_url note attempts

  setup_fixture "stale-dispatch-rework"
  write_mock_issue 9019 "Stale dispatch rework issue" '[{"name":"Ready"}]'
  write_issue_list '[]'

  task_env "$REPO_DIR/scripts/task-start" --issue 9019 --assign-slot slot-r3 --assign-channel exec-r3 >/dev/null
  jq '
    .status = "rework"
    | .pr_url = "https://example.test/pr/9019"
    | .last_review_verdict = "rework"
    | .review_rework_attempts = 1
    | .review_rework_limit = 3
  ' "$REPO_DIR/.harness/tasks/issue-9019/task.json" > "$REPO_DIR/.harness/tasks/issue-9019/task.json.tmp"
  mv "$REPO_DIR/.harness/tasks/issue-9019/task.json.tmp" "$REPO_DIR/.harness/tasks/issue-9019/task.json"
  printf '{}\n' > "$REPO_DIR/.harness/state/claims.json"

  dispatch_output=$(task_env HARNESS_MOCK_CODEX_MODE="touch-readme" "$REPO_DIR/scripts/task-run-once" --dispatch-only --assign-slot slot-r3 --assign-channel exec-r3)
  assert_eq "$dispatch_output" "success: dispatched review rework issue #9019 -> exec-r3/slot-r3" "dispatch-only mode should assign rework to the remote executor slot"

  stale_epoch=$(( $(date -u +%s) - 7200 ))
  stale_iso=$(date -u -r "$stale_epoch" +"%Y-%m-%dT%H:%M:%SZ")
  jq --arg claimed_at "$stale_iso" --argjson claimed_epoch "$stale_epoch" '
    ."example/test-harness#9019".claimed_at = $claimed_at
    | ."example/test-harness#9019".claimed_epoch = $claimed_epoch
  ' "$REPO_DIR/.harness/state/claims.json" > "$REPO_DIR/.harness/state/claims.json.tmp"
  mv "$REPO_DIR/.harness/state/claims.json.tmp" "$REPO_DIR/.harness/state/claims.json"

  cat >>"$REPO_DIR/.harness/project.env" <<'EOF'
HARNESS_CLAIM_TTL_MINUTES="1"
EOF

  run_output=$(task_env HARNESS_MOCK_CODEX_MODE="touch-readme" "$REPO_DIR/scripts/task-run-once")
  assert_eq "$run_output" "success: requeued review rework issue #9019" "expired dispatch-only rework should return to the rework queue instead of reopening the old PR head"

  task_status=$(jq -r '.status' "$REPO_DIR/.harness/tasks/issue-9019/task.json")
  assert_eq "$task_status" "rework" "expired dispatch-only rework should remain in rework state"

  attempts=$(jq -r '.review_rework_attempts' "$REPO_DIR/.harness/tasks/issue-9019/task.json")
  assert_eq "$attempts" "1" "expired dispatch-only rework should preserve the recorded attempt count"

  pr_url=$(jq -r '.pr_url // ""' "$REPO_DIR/.harness/tasks/issue-9019/task.json")
  assert_eq "$pr_url" "https://example.test/pr/9019" "expired dispatch-only rework should preserve the existing PR linkage"

  note=$(jq -r '.note // ""' "$REPO_DIR/.harness/tasks/issue-9019/task.json")
  assert_contains "$note" "expired before execution" "expired dispatch-only rework should explain why it returned to rework"

  claim_count=$(jq 'length' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$claim_count" "0" "expired dispatch-only rework should clear the stale claim"
}

