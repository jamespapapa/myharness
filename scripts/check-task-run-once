  stale_iso=$(date -u -r "$stale_epoch" +"%Y-%m-%dT%H:%M:%SZ")
  jq --arg claimed_at "$stale_iso" --argjson claimed_epoch "$stale_epoch" '
    ."example/test-harness#9014".claimed_at = $claimed_at
    | ."example/test-harness#9014".claimed_epoch = $claimed_epoch
  ' "$REPO_DIR/.harness/state/claims.json" > "$REPO_DIR/.harness/state/claims.json.tmp"
  mv "$REPO_DIR/.harness/state/claims.json.tmp" "$REPO_DIR/.harness/state/claims.json"

