scenario_task_start_launch_marks_claim_running() {
  local pid claim_status task_status output final_status claim_count

  setup_fixture "task-start-launch"
  write_mock_issue 9015 "Direct launch claim status" '[{"name":"Ready"}]'
  write_issue_list '[{"number":9015,"title":"Direct launch claim status","labels":[{"name":"Ready"}]}]'

  task_env HARNESS_MOCK_CODEX_MODE="sleep-touch-readme" "$REPO_DIR/scripts/task-start" --issue 9015 --assign-slot slot-l --assign-channel exec-l --launch codex >"$FIXTURE_DIR/task-start-launch.out" 2>&1 &
  pid=$!

  claim_status=""
  task_status=""
  for _ in $(seq 1 120); do
    if [[ -f "$REPO_DIR/.harness/state/claims.json" && -f "$REPO_DIR/.harness/tasks/issue-9015/task.json" ]]; then
      claim_status=$(jq -r '"example/test-harness#9015" as $k | .[$k].status // ""' "$REPO_DIR/.harness/state/claims.json")
      task_status=$(jq -r '.status // ""' "$REPO_DIR/.harness/tasks/issue-9015/task.json")
      if [[ "$claim_status" == "in_progress" && "$task_status" == "in_progress" ]]; then
        break
      fi
    fi
    sleep 0.1
  done

  assert_eq "$claim_status" "in_progress" "task-start --launch codex should mark the claim running before Codex finishes"
  assert_eq "$task_status" "in_progress" "task-start --launch codex should mark the task in progress before Codex finishes"

  wait "$pid"
  output=$(cat "$FIXTURE_DIR/task-start-launch.out")
  assert_contains "$output" "success: reconciled issue #9015 -> PR https://example.test/pr/9015" "task-start --launch codex should reconcile to pr_open after Codex exits"

  final_status=$(jq -r '.status' "$REPO_DIR/.harness/tasks/issue-9015/task.json")
  assert_eq "$final_status" "pr_open" "task-start launch path should reconcile to pr_open"

  claim_count=$(jq 'length' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$claim_count" "0" "task-start launch path should clear the claim after reconciliation"
}

scenario_assigned_launch_refreshes_claim_timestamp() {
  local stale_epoch stale_iso pid running_status refreshed_epoch output final_status claim_count

  setup_fixture "assigned-launch-refresh"
  cat >>"$REPO_DIR/.harness/project.env" <<'EOF'
HARNESS_EXECUTOR_TIMEOUT_SECONDS="5"
EOF
  write_mock_issue 9018 "Assigned launch refreshes claim timestamp" '[{"name":"Ready"}]'
  write_issue_list '[{"number":9018,"title":"Assigned launch refreshes claim timestamp","labels":[{"name":"Ready"}]}]'

  task_env "$REPO_DIR/scripts/task-start" --issue 9018 --assign-slot slot-r2 --assign-channel exec-r2 >/dev/null

  stale_epoch=$(( $(date -u +%s) - 7200 ))
  stale_iso=$(date -u -r "$stale_epoch" +"%Y-%m-%dT%H:%M:%SZ")
  jq --arg claimed_at "$stale_iso" --argjson claimed_epoch "$stale_epoch" '
    ."example/test-harness#9018".claimed_at = $claimed_at
    | ."example/test-harness#9018".claimed_epoch = $claimed_epoch
  ' "$REPO_DIR/.harness/state/claims.json" > "$REPO_DIR/.harness/state/claims.json.tmp"
  mv "$REPO_DIR/.harness/state/claims.json.tmp" "$REPO_DIR/.harness/state/claims.json"

  write_issue_list '[]'
  task_env HARNESS_MOCK_CODEX_MODE="sleep-touch-readme" "$REPO_DIR/scripts/task-run-once" --assigned-only --assign-slot slot-r2 --assign-channel exec-r2 >"$FIXTURE_DIR/assigned-launch-refresh.out" 2>&1 &
  pid=$!

  running_status=""
  refreshed_epoch=""
  for _ in $(seq 1 120); do
    running_status=$(jq -r '"example/test-harness#9018" as $k | .[$k].status // ""' "$REPO_DIR/.harness/state/claims.json")
    refreshed_epoch=$(jq -r '"example/test-harness#9018" as $k | .[$k].claimed_epoch // 0' "$REPO_DIR/.harness/state/claims.json")
    if [[ "$running_status" == "in_progress" ]]; then
      break
    fi
    sleep 0.1
  done

  assert_eq "$running_status" "in_progress" "assigned-only launch should flip the claim into running state before the worker exits"
  if [[ "$refreshed_epoch" -le "$stale_epoch" ]]; then
    printf 'assert failed: running claim timestamp was not refreshed on launch\nold=%s new=%s\n' "$stale_epoch" "$refreshed_epoch" >&2
    exit 1
  fi

  wait "$pid"
  output=$(cat "$FIXTURE_DIR/assigned-launch-refresh.out")
  assert_eq "$output" "success: reconciled issue #9018 -> PR https://example.test/pr/9018" "assigned-only launch should still reconcile cleanly after refreshing the running claim timestamp"

  final_status=$(jq -r '.status' "$REPO_DIR/.harness/tasks/issue-9018/task.json")
  assert_eq "$final_status" "pr_open" "assigned launch refresh scenario should reconcile to pr_open"

  claim_count=$(jq 'length' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$claim_count" "0" "claim should be cleared after assigned launch reconciliation"
}

scenario_assigned_only_reconciles_stale_in_progress_task() {
  local stale_epoch stale_iso run_output task_status claim_count worktree

  setup_fixture "assigned-stale-running"
  cat >>"$REPO_DIR/.harness/project.env" <<'EOF'
HARNESS_EXECUTOR_TIMEOUT_SECONDS="1"
EOF
  write_mock_issue 9020 "Assigned stale running issue" '[{"name":"Ready"}]'
  write_issue_list '[]'

  task_env "$REPO_DIR/scripts/task-start" --issue 9020 --assign-slot slot-s --assign-channel exec-s >/dev/null
  worktree=$(jq -r '.worktree' "$REPO_DIR/.harness/tasks/issue-9020/task.json")
  printf '\nStale assigned worker change.\n' >>"$worktree/README.md"

  jq '.status = "in_progress"' "$REPO_DIR/.harness/tasks/issue-9020/task.json" > "$REPO_DIR/.harness/tasks/issue-9020/task.json.tmp"
  mv "$REPO_DIR/.harness/tasks/issue-9020/task.json.tmp" "$REPO_DIR/.harness/tasks/issue-9020/task.json"

  stale_epoch=$(( $(date -u +%s) - 7200 ))
  stale_iso=$(date -u -r "$stale_epoch" +"%Y-%m-%dT%H:%M:%SZ")
  jq --arg claimed_at "$stale_iso" --argjson claimed_epoch "$stale_epoch" '
    ."example/test-harness#9020".status = "in_progress"
    | ."example/test-harness#9020".claimed_at = $claimed_at
    | ."example/test-harness#9020".claimed_epoch = $claimed_epoch
  ' "$REPO_DIR/.harness/state/claims.json" > "$REPO_DIR/.harness/state/claims.json.tmp"
  mv "$REPO_DIR/.harness/state/claims.json.tmp" "$REPO_DIR/.harness/state/claims.json"

  run_output=$(task_env HARNESS_MOCK_CODEX_MODE="no-op" "$REPO_DIR/scripts/task-run-once" --assigned-only --assign-slot slot-s --assign-channel exec-s)
  assert_eq "$run_output" "success: reconciled issue #9020 -> PR https://example.test/pr/9020" "assigned-only mode should reconcile a stale running claim before declaring the slot busy"

  task_status=$(jq -r '.status' "$REPO_DIR/.harness/tasks/issue-9020/task.json")
  assert_eq "$task_status" "pr_open" "stale assigned running work should reconcile to pr_open"

  claim_count=$(jq 'length' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$claim_count" "0" "stale assigned running claims should be cleared after reconciliation"
}

scenario_assigned_only_waits_when_slot_busy() {
  local dispatch_one dispatch_two run_output second_status first_claim_status second_claim_status

  setup_fixture "assigned-busy"
  write_mock_issue 9016 "Running assigned issue" '[{"name":"Ready"}]'
  write_mock_issue 9017 "Pending assigned issue" '[{"name":"Ready"}]'
  write_issue_list '[{"number":9016,"title":"Running assigned issue","labels":[{"name":"Ready"}]},{"number":9017,"title":"Pending assigned issue","labels":[{"name":"Ready"}]}]'
  cat >>"$REPO_DIR/.harness/project.env" <<'EOF'
HARNESS_EXECUTOR_ACTIVE_LIMIT="2"
HARNESS_EXECUTOR_TIMEOUT_SECONDS="600"
EOF

  dispatch_one=$(task_env HARNESS_MOCK_CODEX_MODE="no-op" "$REPO_DIR/scripts/task-run-once" --dispatch-only --assign-slot slot-z --assign-channel exec-z)
  assert_eq "$dispatch_one" "success: dispatched issue #9016 -> exec-z/slot-z" "first dispatch should assign issue 9016"

  dispatch_two=$(task_env HARNESS_MOCK_CODEX_MODE="no-op" "$REPO_DIR/scripts/task-run-once" --dispatch-only --assign-slot slot-z --assign-channel exec-z)
  assert_eq "$dispatch_two" "success: dispatched issue #9017 -> exec-z/slot-z" "second dispatch should queue a second task for the same assignment when global capacity allows it"

  jq '
    ."example/test-harness#9016".status = "in_progress"
  ' "$REPO_DIR/.harness/state/claims.json" > "$REPO_DIR/.harness/state/claims.json.tmp"
  mv "$REPO_DIR/.harness/state/claims.json.tmp" "$REPO_DIR/.harness/state/claims.json"

  run_output=$(task_env HARNESS_MOCK_CODEX_MODE="touch-readme" "$REPO_DIR/scripts/task-run-once" --assigned-only --assign-slot slot-z --assign-channel exec-z)
  assert_contains "$run_output" "assignment exec-z/slot-z already has active work; task=issue-9016" "assigned-only workers should refuse a second task while the assignment is already running"

  first_claim_status=$(jq -r '"example/test-harness#9016" as $k | .[$k].status // ""' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$first_claim_status" "in_progress" "the running claim should stay in progress"

  second_claim_status=$(jq -r '"example/test-harness#9017" as $k | .[$k].status // ""' "$REPO_DIR/.harness/state/claims.json")
  assert_eq "$second_claim_status" "assigned" "the queued second claim should remain assigned"

  second_status=$(jq -r '.status' "$REPO_DIR/.harness/tasks/issue-9017/task.json")
  assert_eq "$second_status" "assigned" "the queued second task should remain assigned while the slot is busy"
}

scenario_assigned_only_runs_preassigned_work() {
  local dispatch_output run_output status claim_count assignment_slot assignment_channel

  setup_fixture "assigned-worker"
  write_mock_issue 9012 "Assigned execution issue" '[{"name":"Ready"}]'
  write_issue_list '[{"number":9012,"title":"Assigned execution issue","labels":[{"name":"Ready"}]}]'

  dispatch_output=$(task_env HARNESS_MOCK_CODEX_MODE="no-op" "$REPO_DIR/scripts/task-run-once" --dispatch-only --assign-slot slot-b --assign-channel exec-b)
  assert_eq "$dispatch_output" "success: dispatched issue #9012 -> exec-b/slot-b" "control tower dispatch should assign work before the executor channel runs"

  write_issue_list '[]'
  run_output=$(task_env HARNESS_MOCK_CODEX_MODE="touch-readme" "$REPO_DIR/scripts/task-run-once" --assigned-only --assign-slot slot-b --assign-channel exec-b)
  assert_eq "$run_output" "success: reconciled issue #9012 -> PR https://example.test/pr/9012" "assigned-only mode should execute already-assigned work"

  status=$(jq -r '.status' "$REPO_DIR/.harness/tasks/issue-9012/task.json")
  assert_eq "$status" "pr_open" "assigned task should reconcile to pr_open"

  claim_count=$(jq 'length' "$REPO_DIR/.harness/state/claims.json")
