scenario_task_next_skips_local_in_progress_without_claim() {
  local now_epoch now_iso output

  setup_fixture "next-local-active"
  now_epoch=$(date -u +%s)
  now_iso=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  mkdir -p "$REPO_DIR/.harness/tasks/issue-9022" "$WORKTREE_ROOT/issue-9022"

  cat >"$REPO_DIR/.harness/tasks/issue-9022/task.json" <<EOF
{
  "task_id": "issue-9022",
  "issue_number": 9022,
  "title": "Locally active queued issue",
  "repo_slug": "example/test-harness",
  "branch": "fix/issue-9022",
  "base_branch": "dev",
  "worktree": "$WORKTREE_ROOT/issue-9022",
  "status": "in_progress",
  "created_at": "$now_iso",
  "updated_at": "$now_iso"
}
EOF

  mkdir -p "$REPO_DIR/.harness/state"
  printf '{}\n' > "$REPO_DIR/.harness/state/claims.json"
  write_mock_issue 9022 "Locally active queued issue" '[{"name":"Ready"}]'
  write_issue_list '[{"number":9022,"title":"Locally active queued issue","labels":[{"name":"Ready"}]}]'

  if output=$(task_env "$REPO_DIR/scripts/task-next" 2>&1); then
    printf 'task-next should skip issues that already have a local in_progress task even when claims.json is empty\n' >&2
    exit 1
  fi

  assert_contains "$output" "no eligible issue found" "task-next should ignore issues with a local in_progress task record"
}

