#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=./harness-lib.sh
source "$SCRIPT_DIR/harness-lib.sh"

source_ref=""
title=""
start=0
local_only=0
shared_paths=()
overlay_conflicts=()
verification_requirements=()
migration_notes=()
labels=()

usage() {
  cat <<'EOF'
usage: scripts/task-sync-request --source-ref <version-or-commit> [--title <title>] [--shared-path <path>]... [--overlay-conflict <path>]... [--verify <requirement>]... [--migration-note <note>]... [--label <label>]... [--start] [--local]
EOF
}

emit_code_list() {
  local item

  for item in "$@"; do
    printf -- '- `%s`\n' "$item"
  done
}

emit_text_list() {
  local item

  for item in "$@"; do
    printf -- '- %s\n' "$item"
  done
}

load_default_items() {
  local key="$1"
  local defaults_file="$2"
  local line

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -n "$line" ]] || continue
    printf '%s\n' "$line"
  done < <(jq -r --arg key "$key" '.[$key][]' "$defaults_file")
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --source-ref|--core-ref)
      source_ref="${2:-}"
      shift 2
      ;;
    --title)
      title="${2:-}"
      shift 2
      ;;
    --shared-path)
      shared_paths+=("${2:-}")
      shift 2
      ;;
    --overlay-conflict)
      overlay_conflicts+=("${2:-}")
      shift 2
      ;;
    --verify)
      verification_requirements+=("${2:-}")
      shift 2
      ;;
    --migration-note)
      migration_notes+=("${2:-}")
      shift 2
      ;;
    --label)
      labels+=("${2:-}")
      shift 2
      ;;
    --start)
      start=1
      shift
      ;;
    --local)
      local_only=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      harness_die "unknown argument: $1"
      ;;
  esac
done

[[ -n "$source_ref" ]] || harness_die "provide --source-ref"

harness_load_project_env

repo_root=$(harness_repo_root)
defaults_file="$repo_root/.harness/sync-request.defaults.json"
[[ -f "$defaults_file" ]] || harness_die "sync request defaults not found: $defaults_file"

if [[ "${#shared_paths[@]}" -eq 0 ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    shared_paths+=("$line")
  done < <(load_default_items "shared_paths" "$defaults_file")
fi

if [[ "${#overlay_conflicts[@]}" -eq 0 ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    overlay_conflicts+=("$line")
  done < <(load_default_items "overlay_conflict_points" "$defaults_file")
fi

if [[ "${#verification_requirements[@]}" -eq 0 ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    verification_requirements+=("$line")
  done < <(load_default_items "verification_requirements" "$defaults_file")
fi

if [[ "$local_only" -eq 1 ]]; then
  target_repo="${HARNESS_PROJECT_SLUG:-project/repo}"
else
  target_repo=$(harness_repo_slug)
fi

if [[ -z "$title" ]]; then
  title="Sync harness core from $source_ref"
fi

body=$(
  {
    cat <<EOF
## Problem

- Target repo \`$target_repo\` is behind source harness core \`$source_ref\`.
- Shared harness-core paths should be updated through tracked sync work instead of manual patching.

## Desired Outcome

- Bring \`$target_repo\` forward to \`$source_ref\`.
- Update sync-owned harness paths while preserving project-owned overlay behavior.
- Land the change through the normal harness issue -> review -> prepare -> land flow.

## Sync Source

- Source harness-core version / commit: \`$source_ref\`
- Target repo: \`$target_repo\`

## Expected Shared-Path Updates

EOF
    emit_code_list "${shared_paths[@]}"
    printf '\n## Likely Overlay Conflict Points\n\n'
    emit_code_list "${overlay_conflicts[@]}"
    printf '\n## Verification Requirements\n\n'
    emit_text_list "${verification_requirements[@]}"
    printf '\n## Migration Notes\n\n'
    if [[ "${#migration_notes[@]}" -gt 0 ]]; then
      emit_text_list "${migration_notes[@]}"
    else
      printf '%s\n' '- None recorded at request time.'
    fi
    cat <<'EOF'

## Constraints

- Keep the request auditable through GitHub issue history.
- Preserve project-specific overlay ownership.
- Do not bypass the normal harness review / prepare / land flow.

## Evidence

- `ops/HARNESS_SYNC.md` defines sync as the intended propagation path for shared harness-core updates.
- This issue was generated by `scripts/task-sync-request`.

## Done Conditions

- The sync lands through the normal harness workflow with evidence tied to the resulting head SHA.
- Shared-path updates stay within sync-owned paths unless a temporary divergence is explicitly documented.
- Overlay conflicts are resolved without overwriting project-owned settings.
- Required verification is recorded in the task evidence or PR notes.
EOF
  }
)

intake_args=(--title "$title" --body "$body")

if [[ "$start" -eq 1 ]]; then
  intake_args+=(--start)
elif [[ "$local_only" -eq 0 && -n "${HARNESS_AUTONOMOUS_LABEL:-}" ]]; then
  harness_ensure_label "$target_repo" "$HARNESS_AUTONOMOUS_LABEL" "0e8a16" "Harness issue is ready for autonomous claim"
  intake_args+=(--label "$HARNESS_AUTONOMOUS_LABEL")
fi

if [[ "$local_only" -eq 1 ]]; then
  intake_args+=(--local)
fi

if [[ "${#labels[@]}" -gt 0 ]]; then
  for label in "${labels[@]}"; do
    intake_args+=(--label "$label")
  done
fi

exec "$SCRIPT_DIR/task-intake" "${intake_args[@]}"
